# ==========================================================

def process_string_force(
    index,
    force,
    current_time,
):
    string_number = STRING_NUMBERS[index]

    left_threshold = (
        get_left_hand_threshold(index)
    )

    release_threshold = (
        get_left_hand_release_threshold(
            index
        )
    )


    # ======================================================
    # LEFT HAND MODE
    # ======================================================

    if force >= left_threshold:

        if not left_hand_active[index]:
            left_hand_active[index] = True

            reset_baseline_window(index)
            force_histories[index].clear()

            print()
            print(
                f"******** LEFT HAND "
                f"String {string_number} ********"
            )

        target = force_to_semitones(
            index,
            force,
        )

        set_target_pitch(
            index,
            target,
        )

        if PRINT_LEFT_HAND_DATA:
            displayed_pitch = (
                round(
                    target
                    / PITCH_DISPLAY_STEP
                )
                * PITCH_DISPLAY_STEP
            )

            displayed_pitch = clamp(
                displayed_pitch,
                MIN_SEMITONES,
                MAX_SEMITONES,
            )

            print(
                f"String={string_number}  "
                f"Force={force}  "
                f"Pitch=+{displayed_pitch:.2f}"
            )

        return


    if left_hand_active[index]:

        if force < release_threshold:
            left_hand_active[index] = False

            set_target_pitch(
                index,
                0.0,
            )

            reset_baseline_window(index)
            force_histories[index].clear()

            print(
                f"Left hand released — "
                f"String {string_number}"
            )

        else:
            target = force_to_semitones(
                index,
                force,
            )

            set_target_pitch(
                index,
                target,
            )

            return


    # ======================================================
    # ADAPTIVE BASELINE
    # ======================================================

    baseline_updated = (
        update_adaptive_baseline(
            index,
            force,
            current_time,
        )
    )

    if baseline_updated:
        return


    # ======================================================
    # THREE-POINT PEAK DETECTION
    # ======================================================

    history = force_histories[index]
    history.append(force)

    if len(history) < 3:
        return

    a, b, c = history

    is_local_peak = (
        a < b
        and b > c
    )

    peak_energy = (
        b - BASELINES[index]
    )

    above_peak_threshold = (
        peak_energy
        > PEAK_THRESHOLD_OFFSET
    )

    below_left_hand_threshold = (
        b
        < get_left_hand_threshold(index)
    )

    cooldown_finished = (
        current_time
        - last_trigger_times[index]
        >= PLUCK_COOLDOWN_SECONDS
    )

    if (
        is_local_peak
        and above_peak_threshold
        and below_left_hand_threshold
        and cooldown_finished
    ):
        trigger_string(
            index,
            b,
        )

        last_trigger_times[index] = (
            current_time
        )

        reset_baseline_window(index)
        force_histories[index].clear()


