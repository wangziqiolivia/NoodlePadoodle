def force_to_semitones(index, force):
    left_threshold = (
        get_left_hand_threshold(index)
    )

    max_force = (
        get_left_hand_max_force(index)
    )

    force_range = (
        max_force - left_threshold
    )

    if force_range <= 0:
        return 0.0

    normalized_force = (
        force - left_threshold
    ) / force_range

    normalized_force = clamp(
        normalized_force,
        0.0,
        1.0,
    )

    semitones = (
        MIN_SEMITONES
        + normalized_force
        * (
            MAX_SEMITONES
            - MIN_SEMITONES
        )
    )

    return clamp(
        semitones,
        MIN_SEMITONES,
        MAX_SEMITONES,
    )


def set_target_pitch(index, semitones):
    semitones = clamp(
        semitones,
        MIN_SEMITONES,
        MAX_SEMITONES,
    )

    with state_lock:
        voices[index].target_semitones = (
            semitones
        )


