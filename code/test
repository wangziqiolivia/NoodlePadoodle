def trigger_string(index, peak):
    baseline = BASELINES[index]
    energy = peak - baseline

    if STANDARD_FORCE_OFFSET <= 0:
        volume = 1.0
    else:
        volume = (
            energy / STANDARD_FORCE_OFFSET
        )

    volume = clamp(
        volume,
        MIN_VOLUME,
        MAX_VOLUME,
    )

    string_number = STRING_NUMBERS[index]

    print()
    print("==============================")
    print(f"PLUCK — String {string_number}")
    print(f"Peak     = {peak}")
    print(f"Baseline = {baseline}")
    print(f"Energy   = {energy}")
    print(f"Volume   = {volume:.3f}")

    if not voices[index].audio_available:
        print("Audio path is empty.")

    print("==============================")

    with state_lock:
        voice = voices[index]

        voice.generation += 1
        voice.position = 0.0
        voice.volume = volume

        # 每次拨弦从原音开始
        voice.current_semitones = 0.0
        voice.target_semitones = 0.0

        voice.playing = (
            voice.audio_available
        )


# ==========================================================
# AUDIO CALLBACK
# ==========================================================

def audio_callback(
    outdata,
    frames,
    time_info,
    status,
):
    outdata.fill(0)

    if status:
        print(f"\nAudio status: {status}")

    mixed_output = np.zeros(
        frames,
        dtype=np.float32,
    )

    sample_times = (
        np.arange(
            frames,
            dtype=np.float64,
        )
        / OUTPUT_SAMPLE_RATE
    )

    for index in range(NUM_STRINGS):

        with state_lock:
            voice = voices[index]

            if not voice.playing:
                continue

            local_audio = voice.audio
            local_source_rate = (
                voice.source_sample_rate
            )

            local_position = voice.position
            local_volume = voice.volume

            start_semitones = (
                voice.current_semitones
            )

            local_target = (
                voice.target_semitones
            )

            local_generation = (
                voice.generation
            )


        # ----------------------------------------------
        # PITCH SMOOTHING
        # ----------------------------------------------

        if PITCH_SMOOTH_TIME <= 0:
            semitone_curve = np.full(
                frames,
                local_target,
                dtype=np.float64,
            )

            end_semitones = local_target

        else:
            semitone_curve = (
                local_target
                + (
                    start_semitones
                    - local_target
                )
                * np.exp(
                    -sample_times
                    / PITCH_SMOOTH_TIME
                )
            )

            block_duration = (
                frames
                / OUTPUT_SAMPLE_RATE
            )

            end_semitones = (
                local_target
                + (
                    start_semitones
                    - local_target
                )
                * math.exp(
                    -block_duration
                    / PITCH_SMOOTH_TIME
                )
            )

        semitone_curve = np.clip(
            semitone_curve,
            MIN_SEMITONES,
            MAX_SEMITONES,
        )

        end_semitones = clamp(
            end_semitones,
            MIN_SEMITONES,
            MAX_SEMITONES,
        )


        # ----------------------------------------------
        # SOURCE STEPS
        # ----------------------------------------------

        pitch_ratios = np.power(
            2.0,
            semitone_curve / 12.0,
        )

        sample_rate_ratio = (
            local_source_rate
            / OUTPUT_SAMPLE_RATE
        )

        source_steps = (
            pitch_ratios
            * sample_rate_ratio
        )


        # ----------------------------------------------
        # SOURCE POSITIONS
        # ----------------------------------------------

        cumulative_positions = np.empty(
            frames,
            dtype=np.float64,
        )

        cumulative_positions[0] = 0.0

        if frames > 1:
            cumulative_positions[1:] = (
                np.cumsum(
                    source_steps[:-1]
                )
            )

        source_positions = (
            local_position
            + cumulative_positions
        )

        valid_count = int(
            np.count_nonzero(
                source_positions
                < len(local_audio)
            )
        )


        # ----------------------------------------------
        # LINEAR INTERPOLATION
        # ----------------------------------------------

        if valid_count > 0:
            valid_positions = (
                source_positions[:valid_count]
            )

            index_0 = np.floor(
                valid_positions
            ).astype(np.int64)

            index_1 = np.minimum(
                index_0 + 1,
                len(local_audio) - 1,
            )

            fractions = (
                valid_positions - index_0
            ).astype(np.float32)

            samples_0 = local_audio[index_0]
            samples_1 = local_audio[index_1]

            voice_output = (
                samples_0
                * (1.0 - fractions)
                + samples_1
                * fractions
            )

            voice_output *= local_volume

            mixed_output[:valid_count] += (
                voice_output.astype(
                    np.float32
                )
            )


        # ----------------------------------------------
        # UPDATE VOICE
        # ----------------------------------------------

        next_position = (
            local_position
            + float(
                np.sum(source_steps)
            )
        )

        finished = (
            valid_count < frames
            or next_position
            >= len(local_audio)
        )

        with state_lock:
            voice = voices[index]

            if (
                voice.generation
                == local_generation
            ):
                voice.current_semitones = (
                    end_semitones
                )

                voice.position = (
                    next_position
                )

                if finished:
                    voice.playing = False
                    voice.position = 0.0
                    voice.current_semitones = 0.0
                    voice.target_semitones = 0.0


    mixed_output *= MASTER_GAIN

    mixed_output = np.clip(
        mixed_output,
        -1.0,
        1.0,
    )

    outdata[:, 0] = mixed_output


