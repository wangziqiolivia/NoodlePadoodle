def load_audio_file(path):
    """
    返回：
        audio_data
        source_sample_rate
        audio_available

    路径为空时创建短静音，
    使程序可以继续测试传感器和 baseline。
    """

    if not path.strip():
        silence = np.zeros(
            int(DEFAULT_SAMPLE_RATE * 0.10),
            dtype=np.float32,
        )

        return (
            silence,
            DEFAULT_SAMPLE_RATE,
            False,
        )

    audio_data, source_sample_rate = sf.read(
        path,
        dtype="float32",
        always_2d=True,
    )

    audio_data = audio_data.mean(axis=1)

    audio_data = np.asarray(
        audio_data,
        dtype=np.float32,
    )

    if len(audio_data) < 2:
        raise ValueError(
            f"音频文件太短，无法播放：{path}"
        )

    return (
        audio_data,
        source_sample_rate,
        True,
    )


