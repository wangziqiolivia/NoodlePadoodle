def reset_baseline_window(index):
    baseline_windows[index].clear()


def update_adaptive_baseline(
    index,
    force,
    current_time,
):
    """
    每根弦独立更新 baseline。

    条件：
    - 当前不在左手模式；
    - 连续稳定至少 3 秒；
    - 窗口内 max - min <= 10000。
    """

    if not ADAPTIVE_BASELINE_ENABLED:
        return False

    if left_hand_active[index]:
        reset_baseline_window(index)
        return False

    window = baseline_windows[index]

    window.append(
        (current_time, force)
    )

    cutoff_time = (
        current_time
        - BASELINE_STABLE_SECONDS
    )

    while (
        len(window) >= 2
        and window[1][0] <= cutoff_time
    ):
        window.popleft()

    if len(window) < 2:
        return False

    window_duration = (
        window[-1][0]
        - window[0][0]
    )

    if (
        window_duration
        < BASELINE_STABLE_SECONDS
    ):
        return False

    values = [
        sample_force
        for _, sample_force in window
    ]

    value_range = (
        max(values) - min(values)
    )

    if value_range > BASELINE_STABLE_RANGE:
        return False

    old_baseline = BASELINES[index]

    new_baseline = int(
        round(
            sum(values)
            / len(values)
        )
    )

    if (
        abs(
            new_baseline
            - old_baseline
        )
        < BASELINE_MIN_UPDATE
    ):
        window.clear()
        window.append(
            (current_time, force)
        )
        return False

    BASELINES[index] = new_baseline

    force_histories[index].clear()

    window.clear()
    window.append(
        (current_time, force)
    )

    if PRINT_BASELINE_UPDATES:
        print(
            f"BASELINE ADAPTED — "
            f"String {STRING_NUMBERS[index]}: "
            f"{old_baseline} -> {new_baseline}  "
            f"range={value_range}  "
            f"samples={len(values)}"
        )

    return True


