def read_forces():
    """
    读取 Arduino 的 14 路 CSV。

    Arduino 当前输出顺序：

    1:  String 1
    2:  String 2
    3:  String 3
    4:  String 4
    5:  String 5
    6:  String 6
    7:  String 7
    8:  String 8
    9:  String 9
    10: String 10
    11: String 11
    12: 原 String 14 -> 新 String 12
    13: 原 String 15 -> 新 String 13
    14: 原 String 16 -> 新 String 14
    """

    while True:
        try:
            line = serial_port.readline().decode(
                errors="ignore"
            ).strip()

            if not line:
                continue

            if line.startswith("#"):
                continue

            parts = line.split(",")

            if len(parts) != NUM_STRINGS:
                continue

            try:
                return [
                    int(part.strip())
                    for part in parts
                ]

            except ValueError:
                continue

        except serial.SerialException as error:
            print(f"\nSerial error: {error}")
            raise


