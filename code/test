def calibrate_initial_baselines():
    """
    每根弦独立寻找一个连续 3 秒的稳定窗口。

    窗口满足：
        max(force) - min(force)
        <= INITIAL_CALIBRATION_RANGE

    满足后：
        baseline = 窗口平均值

    校准期间不要拨弦或按弦。
    某一根弦受到干扰时，只会重等那一根，
    不影响已经校准完成的其他弦。
    """

    if not INITIAL_CALIBRATION_ENABLED:
        return

    print()
    print("======================================")
    print(" Initial baseline calibration")
    print(" Keep all strings still")
    print("======================================")
    print()

    windows = [
        deque()
        for _ in range(NUM_STRINGS)
    ]

    calibrated = [
        False
        for _ in range(NUM_STRINGS)
    ]

    while not all(calibrated):
        force_values = read_forces()
        current_time = time.monotonic()

        for index, force in enumerate(
            force_values
        ):
            if calibrated[index]:
                continue

            window = windows[index]

            window.append(
                (current_time, force)
            )

            cutoff_time = (
                current_time
                - INITIAL_CALIBRATION_SECONDS
            )

            while (
                len(window) >= 2
                and window[1][0] <= cutoff_time
            ):
                window.popleft()

            if len(window) < 2:
                continue

            duration = (
                window[-1][0]
                - window[0][0]
            )

            if (
                duration
                < INITIAL_CALIBRATION_SECONDS
            ):
                continue

            values = [
                sample_force
                for _, sample_force in window
            ]

            value_range = (
                max(values) - min(values)
            )

            if (
                value_range
                > INITIAL_CALIBRATION_RANGE
            ):
                continue

            new_baseline = int(
                round(
                    sum(values)
                    / len(values)
                )
            )

            BASELINES[index] = new_baseline
            calibrated[index] = True

            print(
                f"String {STRING_NUMBERS[index]} "
                f"calibrated: "
                f"baseline={new_baseline}, "
                f"range={value_range}, "
                f"samples={len(values)}"
            )

    print()
    print("All 14 baselines calibrated.")
    print()


