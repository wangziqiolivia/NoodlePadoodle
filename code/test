def clamp(value, minimum, maximum):
    return max(minimum, min(maximum, value))


def semitones_to_ratio(semitones):
    return 2.0 ** (semitones / 12.0)


def get_peak_threshold(index):
    return (
        BASELINES[index]
        + PEAK_THRESHOLD_OFFSET
    )


def get_left_hand_threshold(index):
    return (
        BASELINES[index]
        + LEFT_HAND_THRESHOLD_OFFSET
    )


def get_left_hand_release_threshold(index):
    return (
        BASELINES[index]
        + LEFT_HAND_RELEASE_OFFSET
    )


def get_left_hand_max_force(index):
    return (
        get_left_hand_threshold(index)
        + LEFT_HAND_FULL_PRESS_RANGE
    )


