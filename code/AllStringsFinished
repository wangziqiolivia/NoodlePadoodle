def load_audio_file(path):
    audio_data, source_sample_rate = sf.read(
        path,
        dtype="float32",
        always_2d=True,
    )

    # 转换成单声道
    audio_data = audio_data.mean(axis=1)

    audio_data = np.asarray(
        audio_data,
        dtype=np.float32,
    )

    if len(audio_data) < 2:
        raise ValueError(
            f"音频文件太短，无法播放：{path}"
        )

    return audio_data, source_sample_rate


