    for index in range(NUM_STRINGS):
        print(
            f"String {STRING_NUMBERS[index]}: "
            f"{BASELINES[index]}"
        )

    print()
    print(
        f"Peak offset: +{PEAK_THRESHOLD_OFFSET}"
    )

    print(
        f"Left-hand entry offset: "
        f"+{LEFT_HAND_THRESHOLD_OFFSET}"
    )

    print(
        f"Left-hand release offset: "
        f"+{LEFT_HAND_RELEASE_OFFSET}"
    )

    print(
        f"Maximum pitch bend: "
        f"+{MAX_SEMITONES:.2f} semitone"
    )

    print()
    print("Ready!")
    print()


    stream = sd.OutputStream(
        samplerate=OUTPUT_SAMPLE_RATE,
        channels=1,
        dtype="float32",
        blocksize=BLOCK_SIZE,
        latency="low",
        callback=audio_callback,
    )

    stream.start()

    try:
        while True:
            force_values = read_forces()

            current_time = time.monotonic()

            for index, force in enumerate(
                force_values
            ):
                process_string_force(
                    index,
                    force,
                    current_time,
                )

    except KeyboardInterrupt:
        print("\nProgram stopped.")

    finally:
        stream.stop()
        stream.close()

        if serial_port.is_open:
            serial_port.close()


if __name__ == "__main__":
    main()