def read_forces():
    """
    读取 Arduino 输出的一整行 8 路数据。

    Arduino 正确格式：

    value1,value2,value3,value4,
    value5,value6,value7,value8

    自动忽略：
    - 空行
    - 启动提示
    - 以 # 开头的诊断行
    - 数量不是 8 的行
    """

    while True:
        try:
            line = serial_port.readline().decode(
                errors="ignore"
            ).strip()

            if not line:
                continue

            if line.startswith("#"):
                continue

            parts = line.split(",")

            if len(parts) != NUM_STRINGS:
                continue

            try:
                values = [
                    int(part.strip())
                    for part in parts
                ]

            except ValueError:
                continue

            return values

        except serial.SerialException as error:
            print(f"\nSerial error: {error}")
            raise


# ==========================================================
# FORCE TO PITCH
# ==========================================================

def force_to_semitones(index, force):
    """
    每根弦根据自己的 baseline 计算左手音高。

    LEFT_HAND_THRESHOLD:
        0 个半音

    LEFT_HAND_MAX_FORCE:
        1 个半音
    """

    left_threshold = get_left_hand_threshold(index)
    max_force = get_left_hand_max_force(index)

    force_range = max_force - left_threshold

    if force_range <= 0:
        return 0.0

    normalized_force = (
        force - left_threshold
    ) / force_range

    normalized_force = clamp(
        normalized_force,
        0.0,
        1.0,
    )

    semitones = (
        MIN_SEMITONES
        + normalized_force
        * (MAX_SEMITONES - MIN_SEMITONES)
    )

    return clamp(
        semitones,
        MIN_SEMITONES,
        MAX_SEMITONES,
    )


def set_target_pitch(index, semitones):
    semitones = clamp(
        semitones,
        MIN_SEMITONES,
        MAX_SEMITONES,
    )

    with state_lock:
        voices[index].target_semitones = semitones


# ==========================================================
# TRIGGER PLUCK
# ==========================================================

def trigger_string(index, peak):
    baseline = BASELINES[index]

    energy = peak - baseline
    standard_energy = STANDARD_FORCE_OFFSET

    if standard_energy <= 0:
        volume = 1.0
    else:
        volume = energy / standard_energy

    volume = clamp(
        volume,
        MIN_VOLUME,
        MAX_VOLUME,
    )

    string_number = STRING_NUMBERS[index]

    print()
    print("==============================")
    print(f"PLUCK — String {string_number}")
    print(f"Peak     = {peak}")
    print(f"Baseline = {baseline}")
    print(f"Energy   = {energy}")
    print(f"Volume   = {volume:.3f}")
    print("==============================")

    with state_lock:
        voice = voices[index]

        voice.generation += 1

        voice.position = 0.0
        voice.volume = volume

        # 每次重新拨弦时从原音开始
        voice.current_semitones = 0.0
        voice.target_semitones = 0.0

        voice.playing = True


# ==========================================================
# AUDIO CALLBACK
# ==========================================================

def audio_callback(
    outdata,
    frames,
    time_info,
    status,
):
    outdata.fill(0)

    if status:
        print(f"\nAudio status: {status}")

    mixed_output = np.zeros(
        frames,
        dtype=np.float32,
    )

    active_voice_count = 0

    sample_times = (
        np.arange(frames, dtype=np.float64)
        / OUTPUT_SAMPLE_RATE
    )

    for index in range(NUM_STRINGS):

        # ----------------------------------------------
        # COPY CURRENT VOICE STATE
        # ----------------------------------------------

        with state_lock:
            voice = voices[index]

            if not voice.playing:
                continue

            local_audio = voice.audio
            local_source_rate = voice.source_sample_rate

            local_position = voice.position
            local_volume = voice.volume

            start_semitones = voice.current_semitones
            local_target = voice.target_semitones

            local_generation = voice.generation

        active_voice_count += 1


        # ----------------------------------------------
        # EXPONENTIAL PITCH SMOOTHING
        # ----------------------------------------------

        if PITCH_SMOOTH_TIME <= 0:
            semitone_curve = np.full(
                frames,
                local_target,
                dtype=np.float64,
            )

            end_semitones = local_target

        else:
            semitone_curve = (
                local_target
                + (
                    start_semitones
                    - local_target
                )
                * np.exp(
                    -sample_times
                    / PITCH_SMOOTH_TIME
                )
            )

            block_duration = (
                frames / OUTPUT_SAMPLE_RATE
            )

            end_semitones = (
                local_target
                + (
                    start_semitones
                    - local_target
                )
                * math.exp(
                    -block_duration
                    / PITCH_SMOOTH_TIME
                )
            )

        semitone_curve = np.clip(
            semitone_curve,
            MIN_SEMITONES,
            MAX_SEMITONES,
        )

        end_semitones = clamp(
            end_semitones,
            MIN_SEMITONES,
            MAX_SEMITONES,
        )


        # ----------------------------------------------
        # PITCH RATIO
        # ----------------------------------------------

        pitch_ratios = np.power(
            2.0,
            semitone_curve / 12.0,
        )

        # 如果音频文件采样率不同，自动补偿
        sample_rate_ratio = (
            local_source_rate
            / OUTPUT_SAMPLE_RATE
        )

        source_steps = (
            pitch_ratios
            * sample_rate_ratio
        )


        # ----------------------------------------------
        # SOURCE POSITIONS
        # ----------------------------------------------

        cumulative_positions = np.empty(
            frames,
            dtype=np.float64,
        )

        cumulative_positions[0] = 0.0

        if frames > 1:
            cumulative_positions[1:] = np.cumsum(
                source_steps[:-1]
            )

        source_positions = (
            local_position
            + cumulative_positions
        )

        valid_mask = (
            source_positions < len(local_audio)
        )

        valid_count = int(
            np.count_nonzero(valid_mask)
        )


        # ----------------------------------------------
        # LINEAR INTERPOLATION
        # ----------------------------------------------

        if valid_count > 0:
            valid_positions = (
                source_positions[:valid_count]
            )

            index_0 = np.floor(
                valid_positions
            ).astype(np.int64)

            index_1 = np.minimum(
                index_0 + 1,
                len(local_audio) - 1,
            )

            fractions = (
                valid_positions - index_0
            ).astype(np.float32)

            samples_0 = local_audio[index_0]
            samples_1 = local_audio[index_1]

            voice_output = (
                samples_0 * (1.0 - fractions)
                + samples_1 * fractions
            )

            voice_output *= local_volume

            mixed_output[:valid_count] += (
                voice_output.astype(np.float32)
            )


        # ----------------------------------------------
        # UPDATE POSITION
        # ----------------------------------------------

        next_position = (
            local_position
            + float(np.sum(source_steps))
        )

        finished = (
            valid_count < frames
            or next_position >= len(local_audio)
        )

        with state_lock:
            voice = voices[index]

            # 确保播放期间没有被新的拨弦覆盖
            if voice.generation == local_generation:
                voice.current_semitones = end_semitones
                voice.position = next_position

                if finished:
                    voice.playing = False
                    voice.position = 0.0
                    voice.current_semitones = 0.0
                    voice.target_semitones = 0.0


    # ======================================================
    # MIX OUTPUT
    # ======================================================

    if active_voice_count > 0:
        mixed_output *= MASTER_GAIN

        mixed_output = np.clip(
            mixed_output,
            -1.0,
            1.0,
        )

        outdata[:, 0] = mixed_output


# ==========================================================
# DETECTION STATE
# ==========================================================

# 每根弦保存最近三个数据点
force_histories = [
    deque(maxlen=3)
    for _ in range(NUM_STRINGS)
]

# 每根弦是否正在左手按弦
left_hand_active = [
    False
    for _ in range(NUM_STRINGS)
]

# 每根弦最近一次拨弦时间
last_trigger_times = [
    0.0
    for _ in range(NUM_STRINGS)
]


# ==========================================================
# PROCESS ONE STRING
# ==========================================================

def process_string_force(
    index,
    force,
    current_time,
):
    string_number = STRING_NUMBERS[index]

    left_threshold = (
        get_left_hand_threshold(index)
    )

    release_threshold = (
        get_left_hand_release_threshold(index)
    )


    # ======================================================
    # LEFT HAND MODE
    # ======================================================

    if force >= left_threshold:

        if not left_hand_active[index]:
            left_hand_active[index] = True

            print()
            print(
                f"******** LEFT HAND "
                f"String {string_number} ********"
            )

        target = force_to_semitones(
            index,
            force,
        )

        set_target_pitch(
            index,
            target,
        )

        if PRINT_LEFT_HAND_DATA:
            displayed_pitch = (
                round(
                    target / PITCH_DISPLAY_STEP
                )
                * PITCH_DISPLAY_STEP
            )

            displayed_pitch = clamp(
                displayed_pitch,
                MIN_SEMITONES,
                MAX_SEMITONES,
            )

            print(
                f"String={string_number}  "
                f"Force={force}  "
                f"Pitch=+{displayed_pitch:.2f}"
            )

    elif left_hand_active[index]:

        if force < release_threshold:
            left_hand_active[index] = False

            set_target_pitch(
                index,
                0.0,
            )

            print(
                f"Left hand released — "
                f"String {string_number}"
            )

        else:
            # 位于进入阈值和退出阈值之间，
            # 仍保留左手状态并平滑回到原音
            target = force_to_semitones(
                index,
                force,
            )

            set_target_pitch(
                index,
                target,
            )


    # ======================================================
    # THREE-POINT PEAK DETECTION
    # ======================================================

    history = force_histories[index]
    history.append(force)

    if len(history) < 3:
        return

    # 左手模式中不触发拨弦
    if left_hand_active[index]:
        return

    a, b, c = history

    is_local_peak = (
        a < b
        and b > c
    )

    peak_energy = (
        b - BASELINES[index]
    )

    above_peak_threshold = (
        peak_energy
        > PEAK_THRESHOLD_OFFSET
    )

    below_left_hand_threshold = (
        b < left_threshold
    )

    cooldown_finished = (
        current_time
        - last_trigger_times[index]
        >= PLUCK_COOLDOWN_SECONDS
    )

    if (
        is_local_peak
        and above_peak_threshold
        and below_left_hand_threshold
        and cooldown_finished
    ):
        trigger_string(
            index,
            b,
        )

        last_trigger_times[index] = (
            current_time
        )


